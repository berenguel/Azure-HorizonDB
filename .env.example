# Fresh deploy: copy this to .env and fill in the top block. Leave the endpoints
# blank — scripts/01-deploy-cli.sh writes them in for you after the cluster exists.
#
# Existing cluster (e.g. Cloud Shell after a reconnect): don't hand-edit. Run
# ./scripts/bootstrap-env.sh and it rebuilds .env from live Azure state.
#
# .env is gitignored so your password never lands in the repo.

# --- Azure / deployment ---
RESOURCE_GROUP=rg-horizon-demo
LOCATION=centralus          # must be a HorizonDB preview region (see README)
CLUSTER_NAME=horizon-demo
ADMIN_USER=pgadmin          # write-only in Azure; you can't recover it later, so remember it
ADMIN_PASSWORD=ChangeMe_Strong#2026   # likewise write-only — keep it somewhere safe
PG_VERSION=17
VCORES=2
REPLICA_COUNT=2             # >=2 for zonal resilience + reader endpoint + failover
ZONE_PLACEMENT=Strict       # BestEffort | Strict

# --- Connection (filled in automatically after deploy) ---
RW_ENDPOINT=                # = properties.fullyQualifiedDomainName
RO_ENDPOINT=                # = properties.readonlyEndpoint
DB_NAME=postgres

# --- Seed data scale (synthetic storefront) ---
CUSTOMERS=50000
PRODUCTS=1000
ORDERS=500000
